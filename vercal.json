{
    "routes": [
      {
        "src": "/[^.]+",
        "dest": "/index.html",
        "status": 200
      },
      {
        "src": "/static/(.*)",
        "headers": {
          "cache-control": "public, max-age=31536000, immutable"
        },
        "continue": true
      },
      {
        "src": "/(.*)",
        "status": 404,
        "dest": "/index.html"
      }
    ],
    "rewrites": [
      { "source": "/(.*)", "destination": "/index.html" }
    ]
  }